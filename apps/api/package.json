{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nest start --watch --webpack",
    "start:dev": "nest start --watch --webpack",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "jest --testPathPatterns=src/.*\\.spec\\.ts$",
    "test:e2e": "jest --testPathPatterns=test/.*\\.e2e-spec\\.ts$",
    "test:all": "jest",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@eye/game-engine": "workspace:*",
    "@eye/shared-types": "workspace:*",
    "@nestjs/common": "11.0.3",
    "@nestjs/core": "11.0.3",
    "@nestjs/platform-express": "11.0.3",
    "@nestjs/swagger": "11.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "6.5.0",
    "prisma": "6.5.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.5",
    "@nestjs/schematics": "11.0.1",
    "@nestjs/testing": "11.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "22.13.10",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
