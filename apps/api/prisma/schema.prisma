generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  passwordHash        String
  displayName         String
  role                String            @default("player")
  isActive            Boolean           @default(true)
  welcomeBonusClaimed Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  authSessions        AuthSession[]
  passwordResetTokens PasswordResetToken[]
  externalIdentities  ExternalIdentity[]
  wallet              Wallet?
  responsibleGaming   PlayerResponsibleGaming?
  fairnessSeed        PlayerFairnessSeed?
  gameSessions        GameSession[]
  rounds              Round[]
  bonusStates         BonusState[]
  adminActions        AdminAction[]
}

model PlayerResponsibleGaming {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  depositLimitDaily           Decimal? @db.Decimal(18, 2)
  depositLimitWeekly          Decimal? @db.Decimal(18, 2)
  depositLimitMonthly         Decimal? @db.Decimal(18, 2)
  lossLimitDaily              Decimal? @db.Decimal(18, 2)
  lossLimitWeekly             Decimal? @db.Decimal(18, 2)
  lossLimitMonthly            Decimal? @db.Decimal(18, 2)
  sessionTimeLimitMinutes     Int?
  realityCheckIntervalMinutes Int?
  selfExclusionUntil          DateTime?
  cooloffUntil                DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([selfExclusionUntil])
  @@index([cooloffUntil])
}

model PlayerFairnessSeed {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  serverSeed             String
  serverSeedHash         String
  clientSeed             String
  nonce                  Int      @default(0)
  previousServerSeed     String?
  previousServerSeedHash String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model AuthSession {
  id                 String   @id @default(cuid())
  userId             String
  tokenHash          String   @unique
  expiresAt          DateTime
  createdAt          DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  userAgent          String?
  ipAddress          String?
  authSource         String   @default("internal")
  providerKey        String?
  externalSessionRef String?
  lastValidatedAt    DateTime?
  riskFlags          String?
  user               User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
  @@index([authSource])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
}

model Wallet {
  id            String        @id @default(cuid())
  userId        String        @unique
  currencyCode  String        @default("EUR")
  balance       Decimal       @db.Decimal(18, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id           String   @id @default(cuid())
  walletId     String
  roundId      String?
  reason       String
  amount       Decimal  @db.Decimal(18, 2)
  balanceAfter Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())
  metadataJson String?  @db.Text
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  round        Round?   @relation(fields: [roundId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([walletId, createdAt])
  @@index([reason, createdAt])
}

model Game {
  id           String            @id @default(cuid())
  key          String            @unique
  title        String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  mathProfiles GameMathProfile[]
  sessions     GameSession[]
  rounds       Round[]
}

model GameMathProfile {
  id              String   @id @default(cuid())
  gameId          String
  profileId       String   @unique
  label           String
  version         String   @unique
  isLegacy        Boolean  @default(false)
  configJson      String   @db.Text
  targetRtp       Float
  volatilityLabel String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  game            Game     @relation(fields: [gameId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([gameId])
}

model AppSetting {
  key       String   @id
  value     String   @db.VarChar(400)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameSession {
  id              String   @id @default(cuid())
  userId          String
  gameId          String
  activeProfileId String
  configVersion   String
  stateJson       String?  @db.Text
  lastRoundId     String?
  startedAt       DateTime @default(now())
  lastActiveAt    DateTime @default(now())
  endedAt         DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  game            Game     @relation(fields: [gameId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rounds          Round[]

  @@unique([userId, gameId])
  @@index([gameId])
}

model Round {
  id               String        @id @default(cuid())
  userId           String
  gameId           String
  gameSessionId    String?
  profileId        String
  configVersion    String
  seedUsed         String
  clientSeed       String?
  serverSeedHash   String?
  nonce            Int?
  mode             String
  chargedBet       Decimal       @db.Decimal(18, 2)
  bet              Decimal       @db.Decimal(18, 2)
  totalWin         Decimal       @db.Decimal(18, 2)
  walletDelta      Decimal       @db.Decimal(18, 2)
  initialBoardJson String?       @db.Text
  resultJson       String        @db.Text
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  game             Game          @relation(fields: [gameId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  gameSession      GameSession?  @relation(fields: [gameSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bonusStates      BonusState[]
  ledgerEntries    LedgerEntry[]

  @@index([userId, createdAt])
  @@index([gameId, createdAt])
  @@index([gameSessionId])
}

model BonusState {
  id                 String   @id @default(cuid())
  userId             String
  roundId            String?
  mode               String
  freeSpinsRemaining Int
  stickyMultiplier   Int
  totalBonusWin      Decimal  @db.Decimal(18, 2)
  betPerSpin         Decimal  @db.Decimal(18, 2)
  initialBonusBudget Decimal  @db.Decimal(18, 2)
  remainingBonusBudget Decimal @db.Decimal(18, 2)
  preBonusBet        Decimal  @db.Decimal(18, 2)
  stateJson          String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  round              Round?   @relation(fields: [roundId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, updatedAt])
}

model AdminAction {
  id         String   @id @default(cuid())
  userId     String
  actionType String
  payload    String   @db.Text
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  eventType  String
  payload    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}

model ExternalIdentity {
  id               String   @id @default(cuid())
  userId           String
  providerKey      String
  externalUserId   String
  externalUsername String?
  metadataJson     String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([providerKey, externalUserId])
  @@index([userId])
  @@index([providerKey])
}

model AuthNonceReplay {
  id           String   @id @default(cuid())
  nonceOrJti   String
  providerKey  String
  issuedAt     DateTime
  expiresAt    DateTime
  consumedAt   DateTime?
  requestHash  String?
  createdAt    DateTime @default(now())

  @@unique([nonceOrJti, providerKey])
  @@index([expiresAt])
  @@index([providerKey])
}

model AnalyticsRound {
  id             String   @id
  timestampMs    BigInt
  bet            Decimal  @db.Decimal(18, 2)
  win            Decimal  @db.Decimal(18, 2)
  net            Decimal  @db.Decimal(18, 2)
  mode           String
  cascades       Int
  bonusTriggered Boolean
  multiplier     Float
  winMultiple    Float
  tier           String
  balanceAfter   Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())

  @@index([timestampMs])
  @@index([tier])
  @@index([createdAt])
}
