# PostgreSQL connection for local API development.
# Replace placeholders locally. Never commit real secrets.
DATABASE_URL="postgresql://app_user:<postgres_password>@localhost:5432/eye_db?schema=public"

# Optional admin/migration connection when your workflow separates app and owner users.
DATABASE_ADMIN_URL="postgresql://postgres:<postgres_password>@localhost:5432/eye_db?schema=public"

API_DEV_KEY="local-dev-key"
AUTH_COOKIE_SECRET="replace-with-a-long-random-secret"

# Set true only behind HTTPS when iframe/third-party cookie auth is required.
COOKIE_SECURE="false"

# Seed accounts are optional. Leave blank unless a local seed run needs them.
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
PLAYER_SEED_EMAIL=""
PLAYER_SEED_PASSWORD=""

CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3100,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3100"
