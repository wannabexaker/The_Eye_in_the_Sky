# Runtime app user (least-privilege)
# PLACEHOLDER: <app_slot_game_password> must be set locally; never commit a real password.
DATABASE_URL="sqlserver://localhost:1433;database=TheEyeInTheSky;user=app_slot_game;password=<app_slot_game_password>;encrypt=false;trustServerCertificate=true"
# Admin user for migrations only
# PLACEHOLDER: <sa_password> must be set locally; never commit a real password.
DATABASE_ADMIN_URL="sqlserver://localhost:1433;database=TheEyeInTheSky;user=sa;password=<sa_password>;encrypt=false;trustServerCertificate=true"
API_DEV_KEY="local-dev-key"
AUTH_COOKIE_SECRET="replace-with-a-long-random-secret"

# DEVELOPMENT ONLY: Default seeded credentials for initial testing
# ⚠️ IMPORTANT: Shared demo defaults (intentionally public for local demo only).
# Change/remove before production.
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="Channgeme123"
PLAYER_SEED_EMAIL="user@example.com"
PLAYER_SEED_PASSWORD="Changeme123"

CORS_ALLOWED_ORIGINS="http://192.168.1.17:3000,http://192.168.1.17:3100"
