{
  "name": "player-web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"const fs = require('fs'); fs.rmSync('.next', {recursive: true, force: true});\" && next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "node ./scripts/guard-no-dev-server.cjs && next build",
    "build:clean": "node ./scripts/guard-no-dev-server.cjs && node -e \"const fs = require('fs'); fs.rmSync('.next', {recursive: true, force: true});\" && next build",
    "start": "next start",
    "lint": "next lint",
    "optimize:assets": "node ./scripts/optimize-assets.mjs",
    "test": "node --import tsx --test ./lib/**/*.test.ts"
  },
  "dependencies": {
    "@eye/game-engine": "workspace:*",
    "@eye/shared-types": "workspace:*",
    "@eye/ui": "workspace:*",
    "motion": "^12.40.0",
    "next": "15.2.2",
    "pixi.js": "8.10.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "9.22.0",
    "eslint-config-next": "15.2.2",
    "sharp": "0.33.5",
    "tailwindcss": "4.1.1",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
