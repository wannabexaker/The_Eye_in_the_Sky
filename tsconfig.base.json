{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@eye/game-engine": ["packages/game-engine/src/index.ts"],
      "@eye/game-engine/*": ["packages/game-engine/src/*"],
      "@eye/shared-types": ["packages/shared-types/src/index.ts"],
      "@eye/shared-types/*": ["packages/shared-types/src/*"],
      "@eye/ui": ["packages/ui/src/index.ts"],
      "@eye/ui/*": ["packages/ui/src/*"]
    }
  }
}
